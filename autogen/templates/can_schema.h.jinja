{% endif %}
{% endfor %}
} can_tx_t;

typedef struct {
{% for f in dc_frames %}
{% for sig in f.encode %}
    float   {{ sig.name }};
{% endfor %}
{% endfor %}
    bool    fresh;   /* set by can_rx_dispatch when a command frame arrived */
} can_rx_t;

static inline void can_tx_all(const can_tx_t *tx, uint32_t base_mc)
{
    uint8_t buf[8];
{% for f in ws22_frames + debug_frames %}
{% if f.signals %}
    can_pack_{{ f.name }}(buf{% for sig in f.signals %}, tx->{{ sig.name }}{% endfor %});
    can_bus_transmit(CAN_{{ f.name | upper }}_ID(base_mc), buf, 8U);
{% else %}
    can_bus_transmit(CAN_{{ f.name | upper }}_ID(base_mc), tx->{{ f.name }}, 8U);
{% endif %}
{% endfor %}
}

static inline bool can_rx_dispatch(can_rx_t *rx, const can_msg_t *msg, uint32_t base_dc)
{
    if (msg->len < 8U) {
        return false;
    }
{% for f in dc_frames if f.encode %}
    if (msg->id == CAN_{{ f.name | upper }}_ID(base_dc)) {
        can_unpack_{{ f.name }}(msg->data{% for sig in f.encode %}, &rx->{{ sig.name }}{% endfor %});
        rx->fresh = true;
        return true;
    }
{% endfor %}
    return false;
}


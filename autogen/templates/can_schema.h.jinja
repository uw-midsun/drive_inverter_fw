/*
 * Transmit helpers
 * Each frame carries up to two little endian f32 values
 * Usage:
 *   uint8_t buf[8];
 *   can_pack_bus(buf, vbus, ibus);
 *   can_bus_transmit(CAN_BUS_ID(base_mc), buf, 8U);
 */
{% for f in ws22_frames if f.signals %}
static inline void can_pack_{{ f.name }}(
    uint8_t out[8]{% for sig in f.signals %}, float {{ sig.name }}{% endfor %})
{
{% for sig in f.signals %}
    memcpy(&out[{{ loop.index0 * 4 }}], &{{ sig.name }}, 4U);
{% endfor %}
{% if f.signals | length < 2 %}
    memset(&out[4], 0U, 4U);
{% endif %}
}
{% endfor %}
{% for f in debug_frames if f.signals %}
static inline void can_pack_{{ f.name }}(
    uint8_t out[8]{% for sig in f.signals %}, float {{ sig.name }}{% endfor %})
{
{% for sig in f.signals %}
    memcpy(&out[{{ loop.index0 * 4 }}], &{{ sig.name }}, 4U);
{% endfor %}
{% if f.signals | length < 2 %}
    memset(&out[4], 0U, 4U);
{% endif %}
}
{% endfor %}

/*
 * Receive helpers
 * Usage:
 *   float vel_rpm, cur_lim;
 *   can_unpack_drive(msg.data, &vel_rpm, &cur_lim);
 */
{% for f in dc_frames if f.encode %}
static inline void can_unpack_{{ f.name }}(
    const uint8_t in[8]{% for sig in f.encode %}, float *{{ sig.name }}{% endfor %})
{
{% for sig in f.encode %}
    memcpy({{ sig.name }}, &in[{{ loop.index0 * 4 }}], 4U);
{% endfor %}
}
{% endfor %}

